  "query": "SELECT id, work_run_id, sequence, event_type, payload,\n               created_at as \"created_at!: DateTime<Utc>\"\n               FROM (\n                 SELECT * FROM work_run_events\n                 WHERE work_run_id = $1\n                 ORDER BY sequence DESC\n                 LIMIT $2\n               ) sub\n               ORDER BY sequence ASC",
