  "query": "SELECT tm.team_id, tm.user_id, u.email, tm.role, tm.created_at as \"created_at!: chrono::DateTime<chrono::Utc>\"\n             FROM team_members tm\n             INNER JOIN users u ON u.id = tm.user_id\n             WHERE tm.team_id = $1\n             ORDER BY tm.created_at ASC",
